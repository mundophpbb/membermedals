{
    "name": "mundophpbb/membermedals",
    "type": "phpbb-extension",
    "description": "Member Medals for phpBB. A medals and badges system focused on prosilver with a dedicated public page.",
    "version": "0.8.0",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Chico Gois",
            "homepage": "https://github.com/mundophpbb",
            "role": "Developer"
        }
    ],
    "keywords": [
        "phpbb",
        "extension",
        "member",
        "medals",
        "badges",
        "awards",
        "prosilver"
    ],
    "require": {
        "php": ">=8.0",
        "composer/installers": "^1.0 || ^2.0",
        "phpbb/phpbb": ">=3.3.15,<4.0.0@dev"
    },
    "require-dev": {
        "phpbb/epv": "dev-master"
    },
    "extra": {
        "display-name": "Member Medals",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.15,<4.0.0@dev"
        }
    },
    "autoload": {
        "psr-4": {
            "mundophpbb\\membermedals\\": ""
        }
    }
}
